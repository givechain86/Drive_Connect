# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev origin (this repo often uses 3001 when 3000 is busy). Must match
# Supabase → Authentication → URL Configuration → Site URL + Redirect URLs
# (e.g. http://localhost:3001/auth/callback).
# Production: https://driversjobhub.com
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Optional: always use local mock data (ignore Supabase)
# NEXT_PUBLIC_FORCE_MOCK=true

# Demo feedback — optional (banner “Send via email” / “Open form”)
# NEXT_PUBLIC_FEEDBACK_EMAIL=you@example.com
# NEXT_PUBLIC_FEEDBACK_FORM_URL=https://forms.gle/...
